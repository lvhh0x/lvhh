#!/bin/sh
# pre-push — push 전 검증 게이트 (PROFILE.md Done Criteria)
# 실패 시 push 차단. 활성화: git config core.hooksPath .githooks

set -e

echo "[pre-push] 1/3 typecheck: tsc --noEmit"
npx tsc --noEmit

echo "[pre-push] 2/3 JSX 한글 이스케이프 가드"
node scripts/check-jsx-escapes.mjs

echo "[pre-push] 3/3 회귀 테스트: scripts/test-*.ts"
for t in scripts/test-*.ts; do
  echo "[pre-push]   $t"
  npx ts-node -r tsconfig-paths/register --compiler-options '{"module":"commonjs"}' "$t"
done

echo "[pre-push] 모든 검증 통과 — push 진행"
